# GRVTBot Custom - Configuración
# Copia este archivo a .env y rellena con tus valores

# ===== GRVT Credentials =====
# Obtén estos valores de https://grvt.io/exchange/account/api-keys
GRVT_API_KEY=grvt_sk_your_api_key_here
GRVT_SUB_ACCOUNT_ID=your_sub_account_id_here
GRVT_ENVIRONMENT=prod

# ===== Security =====
# Genera con: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
DASHBOARD_API_KEY=your_dashboard_api_key_here

# ===== Server =====
BOT_PORT=3848
NODE_ENV=production

# ===== Optional: Database Encryption =====
# ENCRYPTION_KEY se genera automáticamente si no está presente
# ENCRYPTION_KEY=

# ===== Logging =====
LOG_LEVEL=info
