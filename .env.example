# GRVTBot Custom - Configuración
# Copia este archivo a .env y rellena con tus valores

# ===== GRVT Credentials =====
# Obtén estos valores de https://grvt.io/account/api-keys
GRVT_API_KEY=grvt_sk_your_api_key_here
GRVT_API_SECRET=0xyour_api_secret_here
GRVT_TRADING_ACCOUNT_ID=your_account_id
GRVT_TRADING_ADDRESS=0xyour_trading_address

# ===== Security =====
# Genera con: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
DASHBOARD_API_KEY=your_dashboard_api_key_here

# ===== Server =====
BOT_PORT=3848
NODE_ENV=production

# ===== Optional: Database Encryption =====
# ENCRYPTION_KEY se genera automáticamente si no está presente
# ENCRYPTION_KEY=

# ===== Logging =====
LOG_LEVEL=info
